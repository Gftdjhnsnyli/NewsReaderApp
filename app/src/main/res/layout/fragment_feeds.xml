<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Featured News Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_featured"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="?attr/colorSurface">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="320dp">

                <!-- Featured Image -->
                <ImageView
                    android:id="@+id/img_featured"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_launcher_background"
                    android:contentDescription="Featured News" />

                <!-- Gradient Overlay -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/gradient_overlay" />

                <!-- Bookmark Button -->
                <ImageView
                    android:id="@+id/btn_bookmark_featured"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="12dp"
                    android:padding="8dp"
                    android:src="@android:drawable/btn_star_big_off"
                    android:background="@drawable/rounded_white_background"
                    android:contentDescription="Bookmark"
                    app:tint="@color/white" />

                <!-- Content Container -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Category & Read Time -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_featured_category"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/category_chip_background"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:text="Travel"
                            android:textColor="@android:color/white"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_featured_read_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="5 min reads"
                            android:textColor="@android:color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Title -->
                    <TextView
                        android:id="@+id/tv_featured_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="The UNESCO World Heritage Site with sky-high house prices"
                        android:textColor="@android:color/white"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:lineSpacingMultiplier="1.2"
                        android:maxLines="3"
                        android:ellipsize="end" />

                    <!-- Source & Time -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:id="@+id/img_featured_source"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/ic_dialog_info"
                                android:contentDescription="Source" />

                            <TextView
                                android:id="@+id/tv_featured_source"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="BBC NEWS"
                                android:textColor="@android:color/white"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_featured_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3 hours ago"
                            android:textColor="@android:color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Progress Indicator -->
                    <View
                        android:id="@+id/progress_featured"
                        android:layout_width="100dp"
                        android:layout_height="3dp"
                        android:layout_marginTop="12dp"
                        android:background="@android:color/white" />
                </LinearLayout>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Category Tabs -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:id="@+id/container_categories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- Latest (Selected) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_category_latest"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="12dp"
                    android:text="Latest"
                    android:textAllCaps="false"
                    app:cornerRadius="20dp"
                    app:strokeWidth="0dp"
                    android:backgroundTint="?attr/colorPrimary"
                    android:textColor="@android:color/white" />

                <!-- Business -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_category_business"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="12dp"
                    android:text="Business"
                    android:textAllCaps="false"
                    app:cornerRadius="20dp"
                    app:strokeWidth="1dp" />

                <!-- Sports -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_category_sports"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="12dp"
                    android:text="Sports"
                    android:textAllCaps="false"
                    app:cornerRadius="20dp"
                    app:strokeWidth="1dp" />

                <!-- Politics -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_category_politics"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="12dp"
                    android:text="Politics"
                    android:textAllCaps="false"
                    app:cornerRadius="20dp"
                    app:strokeWidth="1dp" />

                <!-- Technology -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_category_technology"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="12dp"
                    android:text="Technology"
                    android:textAllCaps="false"
                    app:cornerRadius="20dp"
                    app:strokeWidth="1dp" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- News List Container -->
        <LinearLayout
            android:id="@+id/container_news_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- News Item 1 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_news_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <!-- Thumbnail -->
                    <ImageView
                        android:id="@+id/img_news_1"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_launcher_background"
                        android:contentDescription="News Thumbnail" />

                    <!-- Content -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <!-- Category & Read Time -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tv_news_1_category"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Business"
                                android:textSize="12sp"
                                android:textColor="?attr/colorPrimary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="•"
                                android:textSize="12sp"
                                android:textColor="?android:attr/textColorSecondary" />

                            <TextView
                                android:id="@+id/tv_news_1_read_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="12 min reads"
                                android:textSize="12sp"
                                android:textColor="?android:attr/textColorSecondary" />
                        </LinearLayout>

                        <!-- Title -->
                        <TextView
                            android:id="@+id/tv_news_1_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Peak oil is coming. That won't save the world"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="?android:attr/textColorPrimary"
                            android:maxLines="2"
                            android:ellipsize="end" />

                        <!-- Time -->
                        <TextView
                            android:id="@+id/tv_news_1_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="1 min ago"
                            android:textSize="12sp"
                            android:textColor="?android:attr/textColorSecondary" />
                    </LinearLayout>

                    <!-- Bookmark -->
                    <ImageView
                        android:id="@+id/btn_bookmark_1"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="top"
                        android:padding="6dp"
                        android:src="@android:drawable/btn_star_big_off"
                        android:contentDescription="Bookmark"
                        app:tint="?attr/colorPrimary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- News Item 2 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_news_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/img_news_2"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_launcher_background"
                        android:contentDescription="News Thumbnail" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tv_news_2_category"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="World"
                                android:textSize="12sp"
                                android:textColor="?attr/colorPrimary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="•"
                                android:textSize="12sp"
                                android:textColor="?android:attr/textColorSecondary" />

                            <TextView
                                android:id="@+id/tv_news_2_read_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="8 min reads"
                                android:textSize="12sp"
                                android:textColor="?android:attr/textColorSecondary" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_news_2_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Another important news headline here"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="?android:attr/textColorPrimary"
                            android:maxLines="2"
                            android:ellipsize="end" />

                        <TextView
                            android:id="@+id/tv_news_2_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="15 min ago"
                            android:textSize="12sp"
                            android:textColor="?android:attr/textColorSecondary" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/btn_bookmark_2"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="top"
                        android:padding="6dp"
                        android:src="@android:drawable/btn_star_big_off"
                        android:contentDescription="Bookmark"
                        app:tint="?attr/colorPrimary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
